TELEGRAM_PROXY={{ telegram_proxy_effective | quote }}
CONTENT_PROXY={{ content_proxy_effective | quote }}
CONTENT_PROXY_DOMAINS={{ content_proxy_domains_effective | quote }}

TMS_API_ENABLED={{ tms_api_enabled | ternary('true', 'false') }}
