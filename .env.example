# =============================================================================
# LOCAL ANSIBLE INPUT
# =============================================================================
#
# This file is for the local repository checkout. It is read by the Ansible
# installer as controller-side input. It is not the runtime env file used by the
# systemd service on the server.
#
# Ansible generates /etc/telegram-media-server/.env on the server. That generated
# runtime file includes qBittorrent credentials, TMS API key, Prowlarr settings,
# paths, ports, and service defaults.

# Required for a fresh install.
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_PASSWORD=your_admin_password
REGULAR_PASSWORD=your_regular_password

# Optional user preferences.
#LANG=ru

# Optional media directory and DLNA.
# Ansible creates MOVIE_PATH and configures TMS/qBittorrent/minidlna to use it.
#MOVIE_PATH=/media/telegram-media-server
#MINIDLNA_ENABLED=false

# Optional proxy for Telegram Bot API.
#TELEGRAM_PROXY=socks5://127.0.0.1:1080

# Optional proxy for yt-dlp content downloads. Torrent traffic is not proxied.
#CONTENT_PROXY=socks5://127.0.0.1:1080
#CONTENT_PROXY_DOMAINS=youtube.com,youtu.be

# Optional OpenClaw completion webhook.
# Prefer OPENCLAW_ENABLED=true below when OpenClaw should live on the same server.
# Ansible then installs OpenClaw, installs the TMS skill, enables gateway hooks,
# and generates/preserves TMS_WEBHOOK_TOKEN in the server runtime env.
# For the managed OpenClaw /hooks/tms mapping, Ansible defaults the format to openclaw_agent.
#TMS_WEBHOOK_URL=
#TMS_WEBHOOK_TOKEN=
#TMS_WEBHOOK_FORMAT=

# Optional OpenClaw server install.
# When true, Ansible installs OpenClaw on the remote host and configures it for TMS.
#OPENCLAW_ENABLED=false
#OPENCLAW_PROVIDER_ID=custom
#OPENCLAW_PROVIDER_BASE_URL=https://llm.example.com/v1
#OPENCLAW_MODEL=gpt-5.4
#OPENCLAW_FALLBACK_MODELS=
#OPENCLAW_API_KEY=
#OPENCLAW_API_KEY_ENV=
#OPENCLAW_GATEWAY_PORT=18789
#OPENCLAW_TELEGRAM_ENABLED=true
#OPENCLAW_TELEGRAM_BOT_TOKEN=
#OPENCLAW_TELEGRAM_DM_POLICY=pairing
#OPENCLAW_TELEGRAM_ALLOW_FROM=
#OPENCLAW_TELEGRAM_GROUP_POLICY=allowlist
#OPENCLAW_TELEGRAM_GROUP_ALLOW_FROM=
#OPENCLAW_TELEGRAM_GROUPS=
#OPENCLAW_TELEGRAM_GROUPS_REQUIRE_MENTION=true

# Optional media compatibility policy.
# Enable when downloaded videos need to be remuxed/reencoded for older TVs.
#VIDEO_COMPATIBILITY_MODE=false
